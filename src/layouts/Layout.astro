---
export interface Props {
  title: string
}

const { title } = Astro.props
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="No Quarter home page" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="relative mb-52 min-h-screen bg-neutral-900 p-4 md:p-10">
    <div class="fixed top-0 -z-10 h-[1000px] w-[1000px] animate-sway rounded-full bg-pink-900/10 blur-3xl">
    </div>
    <div class="fixed right-0 -z-10 h-[700px] w-[700px] animate-sway2 rounded-full bg-green-900/10 blur-3xl">
    </div>
    <div class="fixed bottom-0 -z-10 h-[400px] w-[400px] animate-sway3 rounded-full bg-blue-900/10 blur-3xl">
    </div>
    <slot />
  </body>
</html>

<style is:global>
  * {
    @apply text-white;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    @apply font-extrabold;
  }
</style>
