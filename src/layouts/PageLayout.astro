---
export interface Props {
  title: string
}

const { title } = Astro.props
---

<div class="py-8">
  <div class="flex flex-col flex-wrap justify-between gap-8 md:flex-row">
    <div>
      <a
        class="w-48 rounded-md border border-neutral-600 px-3 py-1 transition-colors hover:bg-white/5 md:px-4 md:py-2"
        href="/"
      >
        <svg
          class="inline-block h-4 w-4"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 23 23"
          fill="currentColor"
        >
          <path
            d="M10.707 3.293a1 1 0 010 1.414L6.414 9H17a1 1 0 110 2H6.414l4.293 4.293a1 1 0 11-1.414 1.414l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 0z"
          ></path>
        </svg>
        Back
      </a>
    </div>
    <h1 class="mb-10 text-center text-5xl">{title}</h1>
    <div class="hidden w-48 md:block"></div>
  </div>
  <div class="mx-auto max-w-xl">
    <slot />
  </div>
</div>
