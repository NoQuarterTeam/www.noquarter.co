---
import Layout from "../layouts/Layout.astro"
import Filters from "../components/Filters.svelte"
import Content from "../components/Content.svelte"
import Subheader from "../components/Subheader.astro"
export const prerender = true
---

<Layout title="No Quarter">
  <div class="space-y-4 lg:space-y-8">
    <div class="grid w-full grid-cols-1 gap-8 md:gap-10 lg:grid-cols-2">
      <div class="flex flex-col justify-between">
        <div>
          <h1 class="text-5xl md:text-6xl">No Quarter</h1>
          <h2 class="my-8 block pb-4 text-3xl lg:hidden">
            <Subheader />
          </h2>
        </div>
        <div>
          <Filters client:visible />
        </div>
      </div>
      <div class="hidden justify-end lg:flex">
        <h2 class="max-w-xl text-right text-5xl">
          <Subheader />
        </h2>
      </div>
    </div>

    <div>
      <Content client:visible />
    </div>
  </div>
</Layout>
