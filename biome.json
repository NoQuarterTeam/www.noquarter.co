{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",

	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"formatWithErrors": true,
		"indentWidth": 2,
		"lineWidth": 130,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"trailingCommas": "all",
			"semicolons": "asNeeded",
			"arrowParentheses": "always",
			"jsxQuoteStyle": "double"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"a11y": {
				"useKeyWithClickEvents": "off",
				"useMediaCaption": "off"
			},
			"nursery": {
				"useSortedClasses": "off"
			},
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "error"
			},
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "off"
			}
		}
	}
}
